generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ajuste_cabecera {
  numero_ajuste  String           @id @default(dbgenerated()) @db.VarChar(20)
  descripcion    String           @db.VarChar(255)
  fecha          DateTime?        @default(now()) @db.Timestamptz(6)
  impreso        Boolean?         @default(false)
  ajuste_detalle ajuste_detalle[]
}

model ajuste_detalle {
  id_detalle      Int              @id @default(autoincrement())
  numero_ajuste   String?          @db.VarChar(20)
  codigo_producto String?          @db.VarChar(50)
  cantidad        Int
  producto        producto?        @relation(fields: [codigo_producto], references: [codigo], onDelete: NoAction)
  ajuste_cabecera ajuste_cabecera? @relation(fields: [numero_ajuste], references: [numero_ajuste], onDelete: Cascade, onUpdate: NoAction)
}

model movimiento_kardex {
  id_movimiento        Int       @id @default(autoincrement())
  codigo_producto      String?   @db.VarChar(50)
  fecha                DateTime? @default(now()) @db.Timestamptz(6)
  tipo_movimiento      String    @db.VarChar(20)
  documento_referencia String    @db.VarChar(50)
  descripcion          String    @db.VarChar(255)
  cantidad             Int
  costo_unitario       Decimal   @db.Decimal(10, 2)
  valor_total          Decimal   @db.Decimal(10, 2)
  stock_resultante     Int
  producto             producto? @relation(fields: [codigo_producto], references: [codigo], onDelete: NoAction)
}

model producto {
  codigo            String              @id @default(dbgenerated()) @db.VarChar(50)
  nombre            String              @db.VarChar(100)
  descripcion       String?             @db.VarChar(255)
  graba_iva         Boolean             @default(true)
  costo             Decimal             @default(0) @db.Decimal(10, 2)
  pvp               Decimal             @default(0) @db.Decimal(10, 2)
  estado            String              @default("Activo") @db.VarChar(15)
  stock_actual      Int                 @default(0)
  ajuste_detalle    ajuste_detalle[]
  movimiento_kardex movimiento_kardex[]
}
